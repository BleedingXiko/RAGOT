{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "strict": true,
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": false,
    "types": []
  },
  "include": [
    "index.d.ts",
    "RAGOT.d.ts",
    "dist/**/*.d.ts",
    "test-d/**/*.ts"
  ]
}
